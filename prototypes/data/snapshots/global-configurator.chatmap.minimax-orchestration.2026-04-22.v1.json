    {
      "id": "n1",
      "label": "Chat Map: MiniMax M2 local deployment costs + orchestration ceiling",
      "nested": null,
      "resources": [
        {
          "id": "d1",
          "title": "Decision",
          "url": "",
          "note": "Local M2 hosting not cost-justified for Andrew's use case \u2014 MiniMax API at ~$0.30/M tokens vastly cheaper than \u00a3100k+ capex for H100 setup",
          "addedAt": "2026-04-22T22:26:00+01:00"
        },
        {
          "id": "d2",
          "title": "Decision",
          "url": "",
          "note": "Mac Studio M5 Ultra (when released) is the only viable consumer local option \u2014 Current M4 Max tops at 128GB; M3 Ultra at 96GB \u2014 both borderline for 3-bit quant",
          "addedAt": "2026-04-22T22:26:00+01:00"
        },
        {
          "id": "d3",
          "title": "Decision",
          "url": "",
          "note": "Orchestration debt is Andrew's primary AI risk, not hardware gap \u2014 Passive vs active AI use is the real underclass divider",
          "addedAt": "2026-04-22T22:26:00+01:00"
        },
        {
          "id": "q1",
          "title": "Open Question",
          "url": "",
