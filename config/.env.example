# Postgres with pgvector enabled (REQUIRED)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/operator_os

# OpenAI embeddings (OPTIONAL - enables semantic search)
# If not provided, MCP server falls back to lexical search (ILIKE-based)
# OPENAI_API_KEY=your_openai_api_key
# EMBEDDING_MODEL=text-embedding-3-small
